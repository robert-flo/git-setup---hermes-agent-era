[apply]
    whitespace = fix

[color]
    ui = true

[commit]
    verbose = true

[core]
    editor = nvim
    pager = hunk pager
    excludesFile = @CONFIG_DIR@/gitignore.global
    attributesFile = @CONFIG_DIR@/gitattributes.global
    ignorecase = false
    whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol

[credential]
    helper = cache --timeout 3600

[diff]
    colorMoved = default
    algorithm = histogram
    mnemonicPrefix = true

[fetch]
    prune = true
    output = compact

[help]
    autocorrect = 1

[init]
    defaultBranch = master

[interactive]
    diffFilter = delta --color-only --highlight-removed

[log]
    decorate = short

[merge]
    conflictstyle = diff3
    log = true
    stat = true

[protocol]
    version = 2

[pull]
    rebase = true
    ff = only

[push]
    autoSetupRemote = true
    default = current

[rebase]
    autoStash = true
    updateRefs = true
    autoSquash = true

[include]
    path = @CONFIG_DIR@/delta.gitconfig
    path = @CONFIG_DIR@/gitconfig_aliases

[delta]
    features = mantis-shrimp

[rerere]
    enabled = true
    autoupdate = true

[column]
    ui = auto

[branch]
    sort = -committerdate

[tag]
    sort = -version:refname

[filter "lfs"]
    clean = git-lfs clean -- %f
    process = git-lfs filter-process
    required = true
    smudge = git-lfs smudge -- %f

[url "git@github.com:"]
    insteadOf = https://github.com/

[safe]
    directory = *

# Local configuration is intentionally loaded last.
[include]
    path = @CONFIG_DIR@/gitconfig.local
