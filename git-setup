  local gh_user=""
  gh_user=$(gh api user -q .login 2> /dev/null || echo "ravn-ruby-path")
  echo -e "${CYAN}"
  cat << 'BANNER_EOF'
  ╭────────────────────────────────────────────────────╮
  │                                                    │
  │  ██████╗  █████╗ ██╗   ██╗███╗   ██╗               │
  │  ██╔══██╗██╔══██╗██║   ██║████╗  ██║               │
  │  ██████╔╝███████║██║   ██║██╔██╗ ██║               │
  │  ██╔══██╗██╔══██║╚██╗ ██╔╝██║╚██╗██║               │
  │  ██║  ██║██║  ██║ ╚████╔╝ ██║ ╚████║               │
