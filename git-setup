main() {
  verify_dependencies || return 1

  clear || true
  show_ravn_banner

  # Handle command line arguments
  case "${1:-}" in
    verify | v | --verify | -v)
      do_verify
      exit 0
      ;;
    config | f | --config | -f)
      generate_git_config_files
      exit 0
      ;;
    setup | s | --setup | -s)
      do_setup
      exit 0
      ;;
    test | t | --test | -t)
      run_test
      exit 0
      ;;
    clean | c | --clean | -c)
      do_clean
      exit 0
      ;;
    help | h | --help | -h)
      show_help
      exit 0
      ;;
  esac

  # Interactive mode
  while true; do
    show_menu
    read -r choice
    case $choice in
      # An interactive action may report missing configuration with a non-zero
      # status. Keep the menu alive so the user can read the result and choose
      # the next action; direct subcommands retain their exit status above.
      1) do_verify || true ;;
      2) do_setup || true ;;
      3) run_test || true ;;
      4) do_clean || true ;;
      h | H) show_help ;;
      q | Q)
        echo ""
        print_info "Goodbye!"
        exit 0
        ;;
      *) print_error "Invalid option" ;;
    esac
    echo ""
    echo -ne "  ${GRAY}Press Enter to continue...${NC}"
    read -r
    clear || true
    show_ravn_banner
  done
}

main "$@"
