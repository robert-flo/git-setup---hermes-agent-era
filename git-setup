#!/usr/bin/env bash
# User-facing help is implemented by show_help below. Keeping it executable
# makes the interactive menu and command-line help share one source of truth.

set -Eeuo pipefail

#--------------------------------#
# import variables and functions #
#--------------------------------#
# Resolve the project directory and load shared variables and presentation helpers.
scrDir="$(dirname "$(realpath "$0")")"
PROJECT_DIR="$scrDir"
# shellcheck disable=SC1091 # Resolved from the project root.
source "$PROJECT_DIR/helper/set_variable.sh"
# shellcheck disable=SC1091
if ! source "$PROJECT_DIR/lib/global_fn.sh"; then
  echo "Error: unable to source global_fn.sh..."
  exit 1
fi

trap cleanup SIGINT SIGTERM ERR EXIT

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Configuration                                                                │
# └──────────────────────────────────────────────────────────────────────────────┘

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Helper Functions                                                             │
# └──────────────────────────────────────────────────────────────────────────────┘

cleanup() {
  trap - SIGINT SIGTERM ERR EXIT
  if [[ -f /tmp/gpg_batch ]]; then
    rm -f /tmp/gpg_batch
  fi
}

# shellcheck disable=SC1091
source "$PROJECT_DIR/scripts/setup"
# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Test Functions                                                               │
# └──────────────────────────────────────────────────────────────────────────────┘

# shellcheck disable=SC1091
source "$PROJECT_DIR/scripts/test"
# shellcheck disable=SC1091
source "$PROJECT_DIR/scripts/clean"

is_running_in_docker() {
  [[ -f /.dockerenv ]] && return 0
  [[ -r /proc/1/cgroup ]] && grep -qaE '/(docker|containerd)(/|$)' /proc/1/cgroup
}

show_help() {
  print_section "󰋖 Help and Usage"

  cat <<'HELP_EOF'
  git-setup prepares Git, GitHub, SSH, and GPG on Arch Linux.

  BASIC USE
    git-setup              Open the interactive menu
    git-setup <command>    Run one action directly

  COMMANDS
    config   Create or refresh the managed Git configuration files.
    verify   Review Git, SSH, GPG, GitHub, and generated configuration files.
    setup    Configure a new machine with GitHub, SSH, GPG, and commit signing.
    test     Create a test repository and verify a signed commit.
    clean    Remove configuration created by git-setup after confirmation.
    help     Show this guide.

  CONFIGURATION FILES
    config creates these files in ~/.config/git:
      config, delta.gitconfig, gitattributes.global, gitconfig_aliases,
      gitignore.global, and shell_aliases.

    ~/.config/git/gitconfig.local is personal. It is loaded last and is never
    generated, updated, or removed by git-setup.

  GITHUB TOKEN
    Run full setup needs your saved GitHub Personal Access Token to connect
    GitHub CLI and add the public SSH, SSH-signing, and GPG keys it creates.
    Create the token once, keep it in 1Password or Bitwarden, and reuse it
    whenever you configure a new machine.
    See docs/github-token.md for the required scopes and GitHub web steps.

  SETUP
    Full setup asks for your name and email, creates the managed Git files,
    creates or reuses SSH and GPG keys, adds their public keys to GitHub, and
    lets you choose SSH, GPG, or no commit signing.

  INTEGRATION TEST
    The test needs the name and email created by full setup. It creates a
    temporary local repository, makes a signed test commit, and can optionally
    create, push, and remove a temporary GitHub repository.

  DOCKER
    make docker-run starts the same setup in an isolated container. Use your
    saved token when prompted. Keys created inside the container do not persist
    on your computer; their public keys are still added to GitHub.

  AUTOMATION
    Avoid identity prompts with:
      NAME='Ada Lovelace' EMAIL='ada@example.com' git-setup config

  CLEANUP
    clean requires typing yes. It removes git-setup SSH keys, GPG keys for the
    configured email, managed Git files, and the GitHub CLI authentication.
    gitconfig.local is preserved.

  RECOMMENDED FLOW
    1. git-setup verify
    2. git-setup setup
    3. git-setup test
HELP_EOF
}

