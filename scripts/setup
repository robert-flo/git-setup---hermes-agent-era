#!/usr/bin/env bash

# Guided setup command module.
if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  set -Eeuo pipefail
  module_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  # shellcheck disable=SC1091
  source "$module_dir/../helper/set_variable.sh"
  PROJECT_DIR="$GIT_SETUP_ROOT"
  # shellcheck disable=SC1091
  source "$PROJECT_DIR/lib/global_fn.sh"
  # shellcheck disable=SC1091
  source "$PROJECT_DIR/scripts/config"
  # shellcheck disable=SC1091
  source "$PROJECT_DIR/scripts/verify"
fi

prompt_setup_identity() {
  local entered_name=""
  local entered_email=""

  print_info "Git identity for this installation:"

  if [[ -z ${NAME+x} ]]; then
    echo -ne "  ${GRAY}Name [$USER_NAME]:${NC} "
    read -r entered_name
    [[ -n $entered_name ]] && USER_NAME=$entered_name
  fi

  if [[ -z ${EMAIL+x} ]]; then
    echo -ne "  ${GRAY}Email [$USER_EMAIL]:${NC} "
    read -r entered_email
    [[ -n $entered_email ]] && USER_EMAIL=$entered_email
  fi

  print_success "Name: ${WHITE}$USER_NAME${NC}"
  print_success "Email: ${WHITE}$USER_EMAIL${NC}"
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Detection Functions                                                          │
# └──────────────────────────────────────────────────────────────────────────────┘

# shellcheck disable=SC1091 # Module is resolved from the project root.
source "$PROJECT_DIR/scripts/verify"
# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Setup Functions                                                              │
# └──────────────────────────────────────────────────────────────────────────────┘

# shellcheck disable=SC1091 # Module is resolved from the project root.
source "$PROJECT_DIR/scripts/config"

setup_github_auth() {
  print_section "${ICON_GITHUB} GitHub Authentication"
  prompt_setup_identity

  if gh auth status > /dev/null 2>&1; then
    local user=""
    user=$(gh api user -q .login 2> /dev/null || echo "unknown")
    local scopes=""
    scopes=$(gh auth status 2>&1 | grep -oP "Token scopes: '\K[^']+" || echo "unknown")
    print_success "Already authenticated as ${WHITE}@$user${NC}"
    print_info "Token scopes: ${GRAY}$scopes${NC}"
    echo -ne "  ${GRAY}Re-authenticate? (y/N):${NC} "
    read -r reauth
    if [[ ! $reauth =~ ^[yY]$ ]]; then
      return 0
    fi
    gh auth logout --hostname github.com
  fi

  print_step "Enter your GitHub Personal Access Token:"
  echo -ne "  ${GRAY}Token:${NC} "
  read -rs GITHUB_TOKEN
  echo ""

  if [[ -z $GITHUB_TOKEN ]]; then
    print_error "No token provided"
    return 1
  fi

  if echo "$GITHUB_TOKEN" | gh auth login --with-token --hostname github.com; then
    print_success "Authentication successful"
  else
    print_error "Authentication failed"
    return 1
  fi

  unset GITHUB_TOKEN
}

setup_ssh_key() {
  print_section "${ICON_KEY} SSH Key"

  if [[ -f ~/.ssh/id_ed25519 ]]; then
    print_success "Key already exists"
  else
    print_step "Generating ed25519 key..."
    mkdir -p ~/.ssh && chmod 700 ~/.ssh
    ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -N "" -C "$USER_EMAIL"
    print_success "Key generated"
  fi

  local key_title
  key_title="ravn-$(hostname)-$(date +%Y%m%d)"
  if gh ssh-key add ~/.ssh/id_ed25519.pub --title "$key_title" 2> /dev/null; then
    print_success "Authentication key added to GitHub"
  else
    print_info "Authentication key already on GitHub"
  fi

  if gh ssh-key add ~/.ssh/id_ed25519.pub --type signing --title "$key_title (Signing)" 2> /dev/null; then
    print_success "Signing key added to GitHub"
  else
    print_info "Signing key already on GitHub"
  fi
}

setup_gpg_key() {
  print_section "${ICON_LOCK} GPG Key"

  if gpg --list-secret-keys "$USER_NAME" 2> /dev/null | grep -q "$USER_NAME"; then
    print_success "Key already exists"
  else
    print_step "Generating RSA 4096 key..."
    cat > /tmp/gpg_batch << EOF
Key-Type: RSA
Key-Length: 4096
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: $USER_NAME
Name-Email: $USER_EMAIL
Expire-Date: 0
%no-protection
%commit
EOF
    gpg --batch --generate-key /tmp/gpg_batch
    rm -f /tmp/gpg_batch
    print_success "Key generated"
  fi

  GPG_KEY_ID=$(get_gpg_key_id)
  print_info "Key ID: ${WHITE}$GPG_KEY_ID${NC}"

  if [[ -n $GPG_KEY_ID ]]; then
    if gpg --armor --export "$GPG_KEY_ID" | gh gpg-key add - 2> /dev/null; then
      print_success "Key added to GitHub"
    else
      print_info "Key already on GitHub"
    fi
  fi
}

configure_signing() {
  print_section "${ICON_GEAR} Signing Configuration"

  echo -e "  Choose commit signing method:"
  echo -e "    ${CYAN}1${NC}  SSH (Recommended - uses ~/.ssh/id_ed25519.pub)"
  echo -e "    ${CYAN}2${NC}  GPG (Uses GPG key)"
  echo -e "    ${CYAN}3${NC}  None"
  echo ""
  echo -ne "  ${GRAY}Selection [1]:${NC} "
  read -r sign_choice
  sign_choice=${sign_choice:-1}

  # Ensure config directory exists
  mkdir -p "$(dirname "$GIT_CONFIG_FILE")"

  if [[ $sign_choice == "1" ]]; then
    git config --file "$GIT_CONFIG_FILE" gpg.format ssh
    git config --file "$GIT_CONFIG_FILE" user.signingkey "$HOME/.ssh/id_ed25519.pub"
    git config --file "$GIT_CONFIG_FILE" commit.gpgsign true
    git config --file "$GIT_CONFIG_FILE" tag.gpgsign true
    print_success "SSH signing configured in $GIT_CONFIG_FILE"
  elif [[ $sign_choice == "2" ]]; then
    GPG_KEY_ID=$(get_gpg_key_id)
    if [[ -z $GPG_KEY_ID ]]; then
      print_error "No GPG key available!"
      return 1
    fi
    git config --file "$GIT_CONFIG_FILE" gpg.format openpgp
    git config --file "$GIT_CONFIG_FILE" user.signingkey "$GPG_KEY_ID"
    git config --file "$GIT_CONFIG_FILE" commit.gpgsign true
    git config --file "$GIT_CONFIG_FILE" tag.gpgsign true
    print_success "GPG signing configured in $GIT_CONFIG_FILE (Key: $GPG_KEY_ID)"
  else
    git config --file "$GIT_CONFIG_FILE" commit.gpgsign false
    git config --file "$GIT_CONFIG_FILE" tag.gpgsign false
    print_info "Commit signing disabled in $GIT_CONFIG_FILE"
  fi

  git config --file "$GIT_CONFIG_FILE" init.defaultBranch master
  print_success "Default branch set to: ${WHITE}master${NC}"
}

configure_gpg_agent() {
  print_section "${ICON_GEAR} GPG Agent"

  mkdir -p ~/.gnupg && chmod 700 ~/.gnupg

  if [[ ! -f ~/.gnupg/gpg-agent.conf ]] || [[ ! -L ~/.gnupg/gpg-agent.conf ]]; then
    cat > ~/.gnupg/gpg-agent.conf << 'EOF'
default-cache-ttl 600
max-cache-ttl 7200
enable-ssh-support
EOF
    print_success "gpg-agent.conf created"
  else
    print_info "gpg-agent.conf exists"
  fi

  gpgconf --kill gpg-agent 2> /dev/null || true
  gpgconf --launch gpg-agent 2> /dev/null || true
  print_success "Agent restarted"
}

do_setup() {
  setup_github_auth
  generate_git_config_files
  setup_ssh_key
  setup_gpg_key
  configure_signing
  configure_gpg_agent

  print_header "${ICON_CHECK} Setup Complete"
}

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  do_setup
fi
