#!/usr/bin/env bash
# ╭──────────────────────────────────────────────────────────────────────────────╮
# │                                                                              │
# │   ██████╗ ██╗████████╗    ███████╗███████╗████████╗██╗   ██╗██████╗          │
# │  ██╔════╝ ██║╚══██╔══╝    ██╔════╝██╔════╝╚══██╔══╝██║   ██║██╔══██╗         │
# │  ██║  ███╗██║   ██║       ███████╗█████╗     ██║   ██║   ██║██████╔╝         │
# │  ██║   ██║██║   ██║       ╚════██║██╔══╝     ██║   ██║   ██║██╔═══╝          │
# │  ╚██████╔╝██║   ██║       ███████║███████╗   ██║   ╚██████╔╝██║              │
# │   ╚═════╝ ╚═╝   ╚═╝       ╚══════╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝              │
# │                                                                              │
# │            Git + GitHub + GPG Configuration for Arch Linux                   │
# │                                                                              │
# ╰──────────────────────────────────────────────────────────────────────────────╯
# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                          git-setup — Documentación                         ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
# # DESCRIPCIÓN
# Asistente interactivo para configurar Git, GitHub, claves SSH y GPG signing
# en Arch Linux. Ofrece subcomandos para verificar, instalar, probar y limpiar
# la configuración completa del entorno de desarrollo.
#
# # USO BÁSICO
#   git-setup              # Menú interactivo
#   git-setup <comando>    # Modo directo
#
# # SUBCOMANDOS
#
#   verify | -v   — Verifica la configuración actual sin modificar nada
#   config | -f   — Genera los archivos de configuración en ~/.config/git
#   setup  | -s   — Configura desde cero: archivos, gh auth, SSH, GPG, signing
#   test   | -t   — Crea un repo temporal, prueba signed commits, push
#   clean  | -c   — Elimina toda la configuración local (SSH, GPG, gh auth)
#   help   | -h   — Muestra ayuda rápida
#
# # EJEMPLOS
#
#   ## Verificar configuración actual
#   git-setup verify
#   # → Muestra estado de: dependencias, git config, SSH keys, GPG keys, gh auth
#
#   ## Configuración completa desde cero
#   git-setup setup
#   # → Pide token de GitHub
#   # → Genera SSH ed25519 key y la sube a GitHub (auth + signing)
#   # → Genera GPG RSA 4096 key y la sube a GitHub
#   # → Pregunta método de signing (SSH / GPG / None)
#   # → Configura default branch = master
#
#   ## Prueba de integración
#   git-setup test
#   # → Crea /tmp/test-git-<timestamp>/
#   # → Hace signed commit
#   # → Opcional: push a GitHub (crea repo temporal y lo borra)
#   # → Verifica la firma del commit
#
#   ## Limpiar todo
#   git-setup clean
#   # → Elimina ~/.ssh/id_ed25519*
#   # → Elimina todas las GPG keys del usuario
#   # → Elimina gh auth token
#   # → Pide confirmación "yes"
#
#   ## Menú interactivo
#   git-setup
#   # → Muestra menú con opciones 1-4 y q
#
# # COMBINACIONES
#
#   | Modo                          | Comando                       | Resultado                                      |
#   |-------------------------------|-------------------------------|------------------------------------------------|
#   | Verificar solo                | git-setup -v                  | Estado de todo sin cambios                     |
#   | Setup completo                | git-setup -s                  | GitHub SSH GPG config desde cero               |
#   | Test rápido (local)           | git-setup -t                  | Crea repo, prueba signing, no push             |
#   | Test con push                 | git-setup test                | Test + pregunta si hacer push                  |
#   | Clean (con confirmación)      | git-setup -c                  | Pide "yes" antes de borrar                     |
#   | Menú interactivo              | git-setup                     | Navegación por números                         |
#   | Ayuda rápida                  | git-setup help                | Lista de comandos                              |
#
# # FLUJO RECOMENDADO
#   1. git-setup verify     # Ver qué falta
#   2. git-setup setup      # Configurar todo
#   3. git-setup test       # Probar que funciona

set -Eeuo pipefail

#--------------------------------#
# import variables and functions #
#--------------------------------#
# Establece el directorio de trabajo del script e importa variables y funciones globales
# desde global_fn.sh. Si no se puede cargar el archivo, el script termina con error.
scrDir="$(dirname "$(realpath "$0")")"
PROJECT_DIR="${GIT_SETUP_ROOT:-$(cd "$scrDir/.." && pwd)}"
# shellcheck disable=SC1091 # Resolved from the project root.
source "$PROJECT_DIR/helper/set_variable.sh"
# shellcheck disable=SC1091
if ! source "$PROJECT_DIR/lib/global_fn.sh"; then
  echo "Error: unable to source global_fn.sh..."
  exit 1
fi

trap cleanup SIGINT SIGTERM ERR EXIT

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Configuration                                                                │
# └──────────────────────────────────────────────────────────────────────────────┘

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Helper Functions                                                             │
# └──────────────────────────────────────────────────────────────────────────────┘

cleanup() {
  trap - SIGINT SIGTERM ERR EXIT
  if [[ -f /tmp/gpg_batch ]]; then
    rm -f /tmp/gpg_batch
  fi
}

# shellcheck disable=SC1091
source "$PROJECT_DIR/scripts/setup"
# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Test Functions                                                               │
# └──────────────────────────────────────────────────────────────────────────────┘

run_test() {
  print_section "${ICON_ROCKET} Integration Test"

  local repo_name
  repo_name="test-git-$(date +%s)"
  local test_dir="/tmp/$repo_name"
  local test_passed=0
  local test_failed=0
  local pushed_to_github=false
  local commit_signed=false

  # Test 1: Create repository
  print_step "Creating test repository..."
  mkdir -p "$test_dir" && cd "$test_dir"
  if git init -b main > /dev/null 2>&1; then
    print_success "Git repository initialized"
    ((++test_passed))
  else
    print_error "Failed to initialize repository"
    ((++test_failed))
    cd - > /dev/null || true
    return 1
  fi

  # Test 2: Create file and stage
  {
    echo "# Test Repository"
    echo ""
    echo "This is a test repository created by git-setup"
    echo "Created: $(date)"
  } > README.md

  if git add README.md 2> /dev/null; then
    print_success "File staged"
    ((++test_passed))
  else
    print_error "Failed to stage file"
    ((++test_failed))
  fi

  # Test 3: Signed commit
  print_step "Testing signed commit..."
  local commit_output=""
  local commit_result=0
  commit_output=$(git commit -S -m "Test signed commit" 2>&1) || commit_result=$?
  if ((commit_result == 0)); then
    print_success "Signed commit created"
    commit_signed=true
    ((++test_passed))

    # Show commit details
    local commit_hash=""
    commit_hash=$(git rev-parse --short HEAD 2> /dev/null || echo "unknown")
    local commit_author=""
    commit_author=$(git log -1 --format='%an <%ae>' 2> /dev/null || echo "unknown")
    print_info "Commit: ${WHITE}$commit_hash${NC}"
    print_info "Author: ${GRAY}$commit_author${NC}"

    # Verify signature
    print_step "Verifying commit signature..."
    local verify_output=""
    verify_output=$(git log --show-signature -1 2>&1) || true
    if echo "$verify_output" | grep -q -E "Good signature|signature"; then
      print_success "Commit is signed & verified"
      ((++test_passed))
    else
      print_warn "Could not verify signature"
    fi
  else
    print_error "Signed commit failed"
    ((++test_failed))

    # Show why it failed
    if echo "$commit_output" | grep -q "No secret key"; then
      print_info "Reason: GPG/SSH key not found"
    else
      echo -e "    ${GRAY}Error: $commit_output${NC}"
    fi

    print_step "Trying unsigned commit..."
    if git -c commit.gpgsign=false commit -m "Test commit (unsigned)" > /dev/null 2>&1; then
      print_warn "Unsigned commit worked"
    else
      print_error "Even unsigned commit failed"
      ((++test_failed))
    fi
  fi

  # Test 4: Push to GitHub (optional)
  echo ""
  echo -ne "  ${GRAY}Push to GitHub? (y/N):${NC} "
  read -r do_push
  if [[ $do_push =~ ^[yY]$ ]]; then
    print_step "Creating repository on GitHub..."
    local gh_output=""
    local gh_result=0
    gh_output=$(gh repo create "$repo_name" --public --source=. --remote=origin --push 2>&1) || gh_result=$?
    if ((gh_result == 0)); then
      local user=""
      user=$(gh api user -q .login 2> /dev/null || echo "unknown")
      print_success "Repository created and pushed"
      print_info "URL: ${CYAN}https://github.com/$user/$repo_name${NC}"
      pushed_to_github=true
      ((++test_passed))
    else
      print_error "Push failed"
      ((++test_failed))
      echo -e "    ${GRAY}Error: $gh_output${NC}"
    fi
  else
    print_info "Skipped push to GitHub"
  fi

  # Summary
  echo ""
  print_section "󰄬 Test Summary"

  echo -e "  ${WHITE}Results:${NC}"
  echo -e "    ${GREEN}${ICON_CHECK} Passed:${NC} $test_passed"
  echo -e "    ${RED}${ICON_CROSS} Failed:${NC} $test_failed"
  echo ""
  echo -e "  ${WHITE}Details:${NC}"
  echo -e "    Repository:     ${GRAY}$test_dir${NC}"
  if [[ $commit_signed == "true" ]]; then
    echo -e "    Signed commit:  ${GREEN}Yes${NC}"
  else
    echo -e "    Signed commit:  ${RED}No${NC}"
  fi
  if [[ $pushed_to_github == "true" ]]; then
    local user=""
    user=$(gh api user -q .login 2> /dev/null || echo "unknown")
    echo -e "    GitHub:         ${GREEN}github.com/$user/$repo_name${NC}"
  else
    echo -e "    GitHub:         ${GRAY}Not pushed${NC}"
  fi

  # Overall status
  echo ""
  if ((test_failed == 0)); then
    print_success "All tests passed! Your Git setup is working correctly."
  else
    print_warn "Some tests failed. Check the details above."
  fi

  # Cleanup
  echo ""
  print_section "󰃢 Cleanup"

  # Delete local test directory
  cd - > /dev/null || true
  if rm -rf "$test_dir" 2> /dev/null; then
    print_success "Local test directory deleted"
  fi

  # Delete GitHub repository if it was created
  if [[ $pushed_to_github == "true" ]]; then
    local user=""
    user=$(gh api user -q .login 2> /dev/null || echo "unknown")
    print_step "Deleting GitHub repository ${GRAY}$user/$repo_name${NC}..."
    if gh repo delete "$user/$repo_name" --yes 2> /dev/null; then
      print_success "GitHub repository deleted"
    else
      print_warn "Could not delete GitHub repository"
      print_info "Delete manually: ${CYAN}gh repo delete $user/$repo_name --yes${NC}"
    fi
  fi

  print_success "Cleanup complete"
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Main Menu                                                                    │
# └──────────────────────────────────────────────────────────────────────────────┘

show_menu() {
  echo ""
  print_section "${RAVN_ICON[ui_command]} Choose an action"
  echo -e "  ${GREEN}1${NC}  ${RAVN_ICON[ui_check]}  Verify current configuration"
  echo -e "  ${GREEN}2${NC}  ${RAVN_ICON[ui_gear]}  Run full setup"
  echo -e "  ${GREEN}3${NC}  ${RAVN_ICON[ui_test]}  Run integration test"
  echo -e "  ${GREEN}4${NC}  ${RAVN_ICON[ui_trash]}  Clean local config (fresh start)"
  echo -e "  ${GREEN}q${NC}  ${RAVN_ICON[ui_close]}  Exit"
  echo ""
  echo -ne "  ${LIGHT_GRAY}Selection:${NC} "
}

do_clean() {
  print_header "󰃢 Clean Local Git Configuration"

  echo ""
  print_warn "This will remove locally created configuration files:"
  echo ""
  echo -e "    ${GRAY}SSH Keys:${NC}"
  echo -e "      • ~/.ssh/id_ed25519"
  echo -e "      • ~/.ssh/id_ed25519.pub"
  echo ""
  echo -e "    ${GRAY}GPG:${NC}"
  echo -e "      • All GPG secret keys for ${WHITE}$USER_NAME${NC}"
  echo -e "      • ~/.gnupg/gpg-agent.conf"
  echo ""
  echo -e "    ${GRAY}Git Configuration:${NC}"
  echo -e "      • ~/.config/git/config"
  echo -e "      • ~/.config/git/delta.gitconfig"
  echo -e "      • ~/.config/git/gitattributes.global"
  echo -e "      • ~/.config/git/gitconfig_aliases"
  echo -e "      • ~/.config/git/gitignore.global"
  echo -e "      • ~/.config/git/shell_aliases"
  echo -e "      ${GRAY}(gitconfig.local will be preserved)${NC}"
  echo ""
  echo -e "    ${GRAY}GitHub CLI:${NC}"
  echo -e "      • gh authentication token"
  echo ""
  echo -e "    ${RED}${ICON_WARN} This action cannot be undone!${NC}"
  echo ""
  echo -ne "  ${YELLOW}Are you sure? Type 'yes' to confirm:${NC} "
  read -r confirm

  if [[ $confirm != "yes" ]]; then
    print_info "Cancelled"
    return 0
  fi

  print_section "󰃢 Cleaning SSH Keys"

  if [[ -f ~/.ssh/id_ed25519 ]]; then
    rm -f ~/.ssh/id_ed25519 ~/.ssh/id_ed25519.pub
    print_success "Removed SSH keys"
  else
    print_info "No SSH keys found"
  fi

  print_section "󰃢 Cleaning GPG Keys"

  # Get all GPG key IDs for the user
  local gpg_keys=""
  gpg_keys=$(gpg --list-secret-keys --keyid-format LONG "$USER_EMAIL" 2> /dev/null | grep "^sec" | awk '{print $2}' | cut -d'/' -f2 || true)

  if [[ -n $gpg_keys ]]; then
    for key_id in $gpg_keys; do
      print_step "Removing GPG key: ${WHITE}$key_id${NC}"
      # Delete secret key first (required before public)
      gpg --batch --yes --delete-secret-keys "$key_id" 2> /dev/null || true
      gpg --batch --yes --delete-keys "$key_id" 2> /dev/null || true
      print_success "Removed key $key_id"
    done
  else
    print_info "No GPG keys found for $USER_EMAIL"
  fi

  # Remove gpg-agent.conf
  if [[ -f ~/.gnupg/gpg-agent.conf ]]; then
    rm -f ~/.gnupg/gpg-agent.conf
    print_success "Removed gpg-agent.conf"
  fi

  # Restart gpg-agent
  gpgconf --kill gpg-agent 2> /dev/null || true
  print_success "Stopped GPG agent"

  print_section "${ICON_GIT} Cleaning Git Configuration"

  local git_config_file=""
  local removed_git_config=0
  for git_config_file in \
    "$GIT_CONFIG_DIR/config" \
    "$GIT_CONFIG_DIR/delta.gitconfig" \
    "$GIT_CONFIG_DIR/gitattributes.global" \
    "$GIT_CONFIG_DIR/gitconfig_aliases" \
    "$GIT_CONFIG_DIR/gitignore.global" \
    "$GIT_CONFIG_DIR/shell_aliases"; do
    if [[ -f $git_config_file ]]; then
      rm -f "$git_config_file"
      print_success "Removed ${GRAY}${git_config_file/#$HOME/\~}${NC}"
      ((removed_git_config += 1))
    fi
  done
  if ((removed_git_config == 0)); then
    print_info "No generated Git configuration files found"
  else
    print_info "Preserved ${GRAY}~/.config/git/gitconfig.local${NC}"
  fi

  print_section "󰃢 Cleaning GitHub CLI"

  if gh auth status > /dev/null 2>&1; then
    gh auth logout --hostname github.com 2> /dev/null || true
    print_success "Logged out from GitHub CLI"
  else
    print_info "GitHub CLI not authenticated"
  fi

  print_section "${ICON_CHECK} Cleanup Complete"

  echo ""
  print_info "Your local git configuration has been reset."
  print_info "Run option ${WHITE}2${NC} (Full Setup) to reconfigure everything."
  echo ""
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Entry Point                                                                  │
# └──────────────────────────────────────────────────────────────────────────────┘

show_ravn_banner() {
  local gh_user=""
  gh_user=$(gh api user -q .login 2> /dev/null || echo "ravn-ruby-path")
  echo -e "${CYAN}"
  cat << 'BANNER_EOF'
  ╭────────────────────────────────────────────────────╮
  │                                                    │
  │  ██████╗  █████╗ ██╗   ██╗███╗   ██╗               │
  │  ██╔══██╗██╔══██╗██║   ██║████╗  ██║               │
  │  ██████╔╝███████║██║   ██║██╔██╗ ██║               │
  │  ██╔══██╗██╔══██║╚██╗ ██╔╝██║╚██╗██║               │
  │  ██║  ██║██║  ██║ ╚████╔╝ ██║ ╚████║               │
  │  ╚═╝  ╚═╝╚═╝  ╚═╝  ╚═══╝  ╚═╝  ╚═══╝               │
  │                                                    │
  │   Git + GitHub + GPG Configuration for Arch Linux  │
  │                                                    │
BANNER_EOF
  echo -e "  │     ${GRAY}by Roberto Flores ${WHITE}@${gh_user}${CYAN}                  │"
  cat << 'BANNER_EOF'
  │                                                    │
  ╰────────────────────────────────────────────────────╯
BANNER_EOF
  echo -e "${NC}"
}

main() {
  clear || true
  show_ravn_banner

  # Handle command line arguments
  case "${1:-}" in
    verify | v | --verify | -v)
      do_verify
      exit 0
      ;;
    config | f | --config | -f)
      generate_git_config_files
      exit 0
      ;;
    setup | s | --setup | -s)
      do_setup
      exit 0
      ;;
    test | t | --test | -t)
      run_test
      exit 0
      ;;
    clean | c | --clean | -c)
      do_clean
      exit 0
      ;;
    help | h | --help | -h)
      echo "Usage: $0 [command]"
      echo ""
      echo "Commands:"
      echo "  verify   Check current configuration"
      echo "  config   Generate files in ~/.config/git"
      echo "  setup    Generate config and run full setup wizard"
      echo "  test     Run integration test"
      echo "  clean    Clean local config (fresh start)"
      echo ""
      echo "Run without arguments for interactive menu."
      exit 0
      ;;
  esac

  # Interactive mode
  while true; do
    show_menu
    read -r choice
    case $choice in
      1) do_verify ;;
      2) do_setup ;;
      3) run_test ;;
      4) do_clean ;;
      q | Q)
        echo ""
        print_info "Goodbye!"
        exit 0
        ;;
      *) print_error "Invalid option" ;;
    esac
    echo ""
    echo -ne "  ${GRAY}Press Enter to continue...${NC}"
    read -r
    clear || true
    show_ravn_banner
  done
}

main "$@"
