#!/usr/bin/env bash
# ╭──────────────────────────────────────────────────────────────────────────────╮
# │                                                                              │
# │   ██████╗ ██╗████████╗    ███████╗███████╗████████╗██╗   ██╗██████╗          │
# │  ██╔════╝ ██║╚══██╔══╝    ██╔════╝██╔════╝╚══██╔══╝██║   ██║██╔══██╗         │
# │  ██║  ███╗██║   ██║       ███████╗█████╗     ██║   ██║   ██║██████╔╝         │
# │  ██║   ██║██║   ██║       ╚════██║██╔══╝     ██║   ██║   ██║██╔═══╝          │
# │  ╚██████╔╝██║   ██║       ███████║███████╗   ██║   ╚██████╔╝██║              │
# │   ╚═════╝ ╚═╝   ╚═╝       ╚══════╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝              │
# │                                                                              │
# │            Git + GitHub + GPG Configuration for Arch Linux                   │
# │                                                                              │
# ╰──────────────────────────────────────────────────────────────────────────────╯
# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                          git-setup — Documentación                         ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
# # DESCRIPCIÓN
# Asistente interactivo para configurar Git, GitHub, claves SSH y GPG signing
# en Arch Linux. Ofrece subcomandos para verificar, instalar, probar y limpiar
# la configuración completa del entorno de desarrollo.
#
# # USO BÁSICO
#   git-setup              # Menú interactivo
#   git-setup <comando>    # Modo directo
#
# # SUBCOMANDOS
#
#   verify | -v   — Verifica la configuración actual sin modificar nada
#   config | -f   — Genera los archivos de configuración en ~/.config/git
#   setup  | -s   — Configura desde cero: archivos, gh auth, SSH, GPG, signing
#   test   | -t   — Crea un repo temporal, prueba signed commits, push
#   clean  | -c   — Elimina toda la configuración local (SSH, GPG, gh auth)
#   help   | -h   — Muestra ayuda rápida
#
# # EJEMPLOS
#
#   ## Verificar configuración actual
#   git-setup verify
#   # → Muestra estado de: dependencias, git config, SSH keys, GPG keys, gh auth
#
#   ## Configuración completa desde cero
#   git-setup setup
#   # → Pide token de GitHub
#   # → Genera SSH ed25519 key y la sube a GitHub (auth + signing)
#   # → Genera GPG RSA 4096 key y la sube a GitHub
#   # → Pregunta método de signing (SSH / GPG / None)
#   # → Configura default branch = master
#
#   ## Prueba de integración
#   git-setup test
#   # → Crea /tmp/test-git-<timestamp>/
#   # → Hace signed commit
#   # → Opcional: push a GitHub (crea repo temporal y lo borra)
#   # → Verifica la firma del commit
#
#   ## Limpiar todo
#   git-setup clean
#   # → Elimina ~/.ssh/id_ed25519*
#   # → Elimina todas las GPG keys del usuario
#   # → Elimina gh auth token
#   # → Pide confirmación "yes"
#
#   ## Menú interactivo
#   git-setup
#   # → Muestra menú con opciones 1-4 y q
#
# # COMBINACIONES
#
#   | Modo                          | Comando                       | Resultado                                      |
#   |-------------------------------|-------------------------------|------------------------------------------------|
#   | Verificar solo                | git-setup -v                  | Estado de todo sin cambios                     |
#   | Setup completo                | git-setup -s                  | GitHub SSH GPG config desde cero               |
#   | Test rápido (local)           | git-setup -t                  | Crea repo, prueba signing, no push             |
#   | Test con push                 | git-setup test                | Test + pregunta si hacer push                  |
#   | Clean (con confirmación)      | git-setup -c                  | Pide "yes" antes de borrar                     |
#   | Menú interactivo              | git-setup                     | Navegación por números                         |
#   | Ayuda rápida                  | git-setup help                | Lista de comandos                              |
#
# # FLUJO RECOMENDADO
#   1. git-setup verify     # Ver qué falta
#   2. git-setup setup      # Configurar todo
#   3. git-setup test       # Probar que funciona

set -Eeuo pipefail

#--------------------------------#
# import variables and functions #
#--------------------------------#
# Establece el directorio de trabajo del script e importa variables y funciones globales
# desde global_fn.sh. Si no se puede cargar el archivo, el script termina con error.
scrDir="$(dirname "$(realpath "$0")")"
PROJECT_DIR="$(cd "$scrDir/.." && pwd)"
TEMPLATE_DIR="$PROJECT_DIR/templates/git"
# shellcheck disable=SC1091
if ! source "$PROJECT_DIR/lib/global_fn.sh"; then
  echo "Error: unable to source global_fn.sh..."
  exit 1
fi

trap cleanup SIGINT SIGTERM ERR EXIT

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Configuration                                                                │
# └──────────────────────────────────────────────────────────────────────────────┘

GIT_CONFIG_DIR="$HOME/.config/git"
GIT_CONFIG_FILE="$GIT_CONFIG_DIR/config"

# User configuration (edit these)
USER_NAME="${NAME:-Roberto Flores}"
USER_EMAIL="${EMAIL:-25asab015@ujmd.edu.sv}"

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Helper Functions                                                             │
# └──────────────────────────────────────────────────────────────────────────────┘

cleanup() {
  trap - SIGINT SIGTERM ERR EXIT
  if [[ -f /tmp/gpg_batch ]]; then
    rm -f /tmp/gpg_batch
  fi
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Detection Functions                                                          │
# └──────────────────────────────────────────────────────────────────────────────┘

get_gpg_key_id() {
  local key_id=""

  # Try by name
  key_id=$(gpg --list-secret-keys --keyid-format SHORT "$USER_NAME" 2> /dev/null | grep "^sec" | head -1 | awk '{print $2}' | cut -d'/' -f2 || true)

  # Try by email
  if [[ -z $key_id ]]; then
    key_id=$(gpg --list-secret-keys --keyid-format SHORT "$USER_EMAIL" 2> /dev/null | grep "^sec" | head -1 | awk '{print $2}' | cut -d'/' -f2 || true)
  fi

  # Try any RSA key
  if [[ -z $key_id ]]; then
    key_id=$(gpg --list-secret-keys --keyid-format SHORT 2> /dev/null | grep "^sec" | grep "rsa4096" | head -1 | awk '{print $2}' | cut -d'/' -f2 || true)
  fi

  echo "$key_id"
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Verification Functions                                                       │
# └──────────────────────────────────────────────────────────────────────────────┘

verify_dependencies() {
  print_section "${ICON_PACKAGE} Checking Dependencies"

  local missing=0

  for cmd in git gh gpg ssh-keygen; do
    if command_exists "$cmd"; then
      print_success "$cmd installed"
    else
      print_error "$cmd not found"
      missing=1
    fi
  done

  if ((missing == 1)); then
    echo ""
    print_info "Install missing packages on Arch Linux:"
    echo -e "${GRAY}    sudo pacman -S git github-cli gnupg openssh git-delta${NC}"
    exit 1
  fi
}

verify_git_config() {
  print_section "${ICON_GIT} Git Configuration"

  # 1. Check user name
  local name=""
  if [[ -f $GIT_CONFIG_FILE ]]; then
    name=$(git config --file "$GIT_CONFIG_FILE" user.name 2> /dev/null || echo "")
  else
    name=$(git config --global user.name 2> /dev/null || echo "")
  fi

  if [[ -n $name ]]; then
    print_success "Name: ${WHITE}$name${NC}"
  else
    print_error "Name not configured"
    print_info "Expected: ${GRAY}$USER_NAME${NC}"
  fi

  # 2. Check user email
  local email=""
  if [[ -f $GIT_CONFIG_FILE ]]; then
    email=$(git config --file "$GIT_CONFIG_FILE" user.email 2> /dev/null || echo "")
  else
    email=$(git config --global user.email 2> /dev/null || echo "")
  fi

  if [[ -n $email ]]; then
    print_success "Email: ${WHITE}$email${NC}"
  else
    print_error "Email not configured"
    print_info "Expected: ${GRAY}$USER_EMAIL${NC}"
  fi

  # 3. Check configuration path
  if [[ -f ~/.config/git/config ]]; then
    print_success "Config file: ${GRAY}~/.config/git/config${NC}"
  elif [[ -f ~/.gitconfig ]]; then
    print_success "Config file: ${GRAY}~/.gitconfig${NC}"
  else
    print_warn "No Git configuration file found"
  fi

  # 4. Check commit signing preference
  local gpg_sign="false"
  if [[ -f $GIT_CONFIG_FILE ]]; then
    gpg_sign=$(git config --file "$GIT_CONFIG_FILE" commit.gpgsign 2> /dev/null || echo "false")
  else
    gpg_sign=$(git config --global commit.gpgsign 2> /dev/null || echo "false")
  fi

  if [[ $gpg_sign == "true" ]]; then
    print_success "Commit signing: ${WHITE}enabled${NC}"
  else
    print_warn "Commit signing: ${YELLOW}disabled${NC}"
  fi

  # 5. Check default branch
  local default_branch=""
  if [[ -f $GIT_CONFIG_FILE ]]; then
    default_branch=$(git config --file "$GIT_CONFIG_FILE" init.defaultBranch 2> /dev/null || echo "")
  else
    default_branch=$(git config --global init.defaultBranch 2> /dev/null || echo "")
  fi

  if [[ -n $default_branch ]]; then
    print_success "Default branch: ${WHITE}$default_branch${NC}"
  else
    print_info "Default branch: ${GRAY}not set (uses 'master')${NC}"
  fi
}

verify_generated_git_config_files() {
  local git_config_file=""

  print_section "${RAVN_ICON[documents_file]} Generated Git Configuration Files"

  for git_config_file in \
    config \
    delta.gitconfig \
    gitattributes.global \
    gitconfig_aliases \
    gitignore.global \
    shell_aliases; do
    if [[ -f $GIT_CONFIG_DIR/$git_config_file ]]; then
      print_success "Found: ${GRAY}~/.config/git/$git_config_file${NC}"
    else
      print_error "Missing: ${GRAY}~/.config/git/$git_config_file${NC}"
    fi
  done
}

verify_ssh() {
  print_section "${ICON_KEY} SSH Authentication"

  # 1. Check for SSH keys
  local key_type=""
  local key_path=""

  if [[ -f $HOME/.ssh/id_ed25519 ]]; then
    key_type="ed25519"
    key_path="$HOME/.ssh/id_ed25519"
    print_success "SSH key found: ${WHITE}$key_type${NC} ${GRAY}(${key_path/#$HOME/\~})${NC}"
  elif [[ -f $HOME/.ssh/id_rsa ]]; then
    key_type="RSA"
    key_path="$HOME/.ssh/id_rsa"
    print_success "SSH key found: ${WHITE}$key_type${NC} ${GRAY}(${key_path/#$HOME/\~})${NC}"
  else
    print_error "No SSH key found"
    print_info "Run setup to generate a new key"
    return 1
  fi

  # 2. Check public key exists
  if [[ -f $key_path.pub ]]; then
    print_success "Public key exists"
  else
    print_error "Public key missing: ${GRAY}${key_path/#$HOME/\~}.pub${NC}"
  fi

  # 3. Check SSH agent and load key if needed
  if [[ -n ${SSH_AUTH_SOCK:-} ]]; then
    local loaded_keys=0
    loaded_keys=$(ssh-add -l 2> /dev/null | grep -c "SHA256" || true)
    loaded_keys=${loaded_keys//[^0-9]/}
    [[ -z $loaded_keys ]] && loaded_keys=0

    if ((loaded_keys > 0)); then
      print_success "SSH agent running: ${WHITE}$loaded_keys${NC} key(s) loaded"
    else
      print_warn "SSH agent running but no keys loaded"
      print_step "Loading SSH key into agent..."
      if ssh-add "$key_path" 2> /dev/null; then
        print_success "SSH key loaded into agent"
      else
        print_error "Failed to load SSH key"
        print_info "Try manually: ${GRAY}ssh-add ${key_path/#$HOME/\~}${NC}"
      fi
    fi
  else
    print_warn "SSH agent not detected"
  fi

  # 4. Test GitHub SSH connection
  print_step "Testing GitHub SSH connection..."
  local ssh_output=""
  ssh_output=$(ssh -T git@github.com 2>&1 || true)
  if echo "$ssh_output" | grep -q "successfully authenticated"; then
    local gh_user=""
    gh_user=$(echo "$ssh_output" | grep -oP "Hi \K[^!]+" || echo "")
    print_success "GitHub SSH working: ${WHITE}@$gh_user${NC}"
  elif echo "$ssh_output" | grep -q "Permission denied"; then
    print_error "GitHub SSH denied"
    print_info "Key may not be uploaded to GitHub"
  else
    print_warn "GitHub SSH connection unclear"
    echo -e "    ${GRAY}$(echo "$ssh_output" | head -1)${NC}"
  fi

  # 5. Check if key is on GitHub
  if command_exists gh && gh auth status > /dev/null 2>&1; then
    local local_key=""
    local_key=$(awk '{print $1" "$2}' "$key_path.pub" 2> /dev/null || echo "")
    local key_title=""

    if [[ -n $local_key ]]; then
      # Check authentication keys
      key_title=$(gh api user/keys --jq ".[] | select(.key | startswith(\"$local_key\")) | .title" 2> /dev/null || echo "")
      # If not found, check signing keys
      if [[ -z $key_title ]]; then
        key_title=$(gh api user/ssh_signing_keys --jq ".[] | select(.key | startswith(\"$local_key\")) | .title" 2> /dev/null || echo "")
        [[ -n $key_title ]] && key_title="$key_title (Signing)"
      fi
    fi

    if [[ -z $local_key ]]; then
      print_warn "Could not read local public key"
    elif [[ -z $key_title ]]; then
      print_warn "Key not on GitHub"
      print_step "Uploading SSH key to GitHub..."
      local key_title_new
      key_title_new="ravn-$(hostname)-$(date +%Y%m%d)"
      if gh ssh-key add "$key_path.pub" --title "$key_title_new" 2> /dev/null; then
        print_success "Authentication key uploaded: ${WHITE}$key_title_new${NC}"
      else
        print_error "Failed to upload authentication key"
        print_info "Try manually: ${GRAY}gh ssh-key add ${key_path/#$HOME/\~}.pub${NC}"
      fi

      if gh ssh-key add "$key_path.pub" --type signing --title "$key_title_new (Signing)" 2> /dev/null; then
        print_success "Signing key uploaded: ${WHITE}$key_title_new (Signing)${NC}"
      else
        print_error "Failed to upload signing key"
      fi
    else
      print_success "Key registered on GitHub"
      print_info "Title: ${GRAY}$key_title${NC}"
    fi
  else
    print_warn "Cannot check GitHub keys ${GRAY}(gh not authenticated)${NC}"
  fi
}

verify_gpg() {
  print_section "${ICON_LOCK} GPG Signing"

  # 1. Check if GPG keys exist
  local total_keys=0
  total_keys=$(gpg --list-secret-keys 2> /dev/null | grep -c "^sec" || true)
  if ((total_keys == 0)); then
    print_error "No GPG secret keys found on system"
    print_info "Run setup to generate a new key"
    return 1
  else
    print_success "Secret keys on system: ${WHITE}$total_keys${NC}"
  fi

  # 2. Find key for configured user
  GPG_KEY_ID=$(get_gpg_key_id)
  if [[ -z $GPG_KEY_ID ]]; then
    print_error "No key found for ${YELLOW}$USER_NAME${NC} or ${YELLOW}$USER_EMAIL${NC}"
    print_info "Available keys:"
    gpg --list-secret-keys --keyid-format SHORT 2> /dev/null | grep -E "^sec|^uid" | while read -r line; do
      echo -e "    ${GRAY}$line${NC}"
    done
    return 1
  else
    print_success "Key for user: ${WHITE}$GPG_KEY_ID${NC}"
  fi

  # 3. Check if key exists in secret keyring (can sign)
  if gpg --list-secret-keys "$GPG_KEY_ID" > /dev/null 2>&1; then
    print_success "Secret key available for signing"
  else
    print_error "Secret key ${YELLOW}$GPG_KEY_ID${NC} not found"
    print_info "The key may have been deleted or is on another machine"
    return 1
  fi

  # 4. Check Git's configured signing key
  local configured_key=""
  if [[ -f $GIT_CONFIG_FILE ]]; then
    configured_key=$(git config --file "$GIT_CONFIG_FILE" user.signingkey 2> /dev/null || echo "")
  else
    configured_key=$(git config --global user.signingkey 2> /dev/null || echo "")
  fi

  if [[ -z $configured_key ]]; then
    print_warn "No signing key configured in Git"
  elif [[ $configured_key == "$GPG_KEY_ID" ]]; then
    print_success "Git GPG signing key matches: ${WHITE}$configured_key${NC}"
  elif [[ $configured_key == *".pub" ]]; then
    print_success "Git configured to use SSH key for signing: ${WHITE}$configured_key${NC}"
  else
    print_error "Git signing key mismatch!"
    echo -e "    ${GRAY}Git configured:${NC} ${RED}$configured_key${NC}"
    echo -e "    ${GRAY}System key:${NC}     ${GREEN}$GPG_KEY_ID${NC}"
    print_info "Run setup (Option 2) to configure or fix"
  fi

  # 5. Check if key is on GitHub
  if command_exists gh && gh auth status > /dev/null 2>&1; then
    local key_found_gh=""
    key_found_gh=$(gh api user/gpg_keys --jq ".[] | select(.key_id | ascii_upcase | endswith(\"${GPG_KEY_ID^^}\")) | .key_id" 2> /dev/null || echo "")
    if [[ -n $key_found_gh ]]; then
      print_success "GPG key uploaded to GitHub"
    else
      print_warn "GPG key not on GitHub"
      print_step "Uploading GPG key to GitHub..."
      if gpg --armor --export "$GPG_KEY_ID" | gh gpg-key add - 2> /dev/null; then
        print_success "GPG key uploaded to GitHub"
      else
        print_error "Failed to upload GPG key"
        print_info "Try manually: ${GRAY}gpg --armor --export $GPG_KEY_ID | gh gpg-key add -${NC}"
      fi
    fi
  else
    print_warn "Cannot check GitHub GPG keys ${GRAY}(gh not authenticated)${NC}"
  fi

  # 6. Test actual signing capability
  print_step "Testing GPG signing..."
  local sign_output=""
  local sign_result=0
  sign_output=$(echo "test" | gpg --clearsign 2>&1) || sign_result=$?
  if ((sign_result == 0)); then
    print_success "GPG signing works correctly"
  else
    print_error "GPG signing failed"
    # Show specific error
    if echo "$sign_output" | grep -q "No secret key"; then
      print_info "Secret key not available for signing"
    elif echo "$sign_output" | grep -q "pinentry"; then
      print_info "Pinentry not configured correctly"
    elif echo "$sign_output" | grep -q "agent"; then
      print_info "GPG agent not running: ${GRAY}gpgconf --launch gpg-agent${NC}"
    else
      echo -e "    ${GRAY}Error: $(echo "$sign_output" | head -1)${NC}"
    fi
  fi

  # 7. Check GPG agent status
  if pgrep -x gpg-agent > /dev/null 2>&1; then
    print_success "GPG agent running"
  else
    print_warn "GPG agent not running"
    print_info "Start with: ${GRAY}gpgconf --launch gpg-agent${NC}"
  fi
}

verify_github_auth() {
  print_section "${ICON_GITHUB} GitHub CLI"

  # 1. Check if gh is installed
  if ! command_exists gh; then
    print_error "GitHub CLI (gh) not installed"
    print_info "Install with: ${GRAY}sudo pacman -S github-cli${NC}"
    return 1
  fi
  print_success "GitHub CLI installed"

  # 2. Check authentication status
  local auth_status=""
  auth_status=$(gh auth status 2>&1 || true)
  if echo "$auth_status" | grep -q "Logged in"; then
    local user=""
    user=$(gh api user -q .login 2> /dev/null || echo "unknown")
    local email=""
    email=$(gh api user -q .email 2> /dev/null || echo "private")
    print_success "Authenticated as ${WHITE}@$user${NC}"
    if [[ $email != "null" && $email != "private" ]]; then
      print_info "GitHub email: ${GRAY}$email${NC}"
    fi
  else
    print_error "Not authenticated with GitHub"
    print_info "Run setup or: ${GRAY}gh auth login${NC}"
    return 1
  fi

  # 3. Check token scopes
  local scopes=""
  scopes=$(gh auth status 2>&1 | grep -oP "Token scopes: '\K[^']+" || echo "")
  if [[ -n $scopes ]]; then
    print_success "Token scopes: ${GRAY}$scopes${NC}"
  fi

  # 4. Check git protocol
  local protocol=""
  protocol=$(gh config get git_protocol 2> /dev/null || echo "https")
  print_info "Git protocol: ${WHITE}$protocol${NC}"

  # 5. Test API access
  print_step "Testing GitHub API..."
  if gh api user > /dev/null 2>&1; then
    print_success "API access working"
  else
    print_error "API access failed"
  fi
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Setup Functions                                                              │
# └──────────────────────────────────────────────────────────────────────────────┘

generate_git_config_files() {
  print_section "${RAVN_ICON[ui_gear]} Git Configuration Files"

  local -a generated_files=(
    "$GIT_CONFIG_FILE"
    "$GIT_CONFIG_DIR/delta.gitconfig"
    "$GIT_CONFIG_DIR/gitattributes.global"
    "$GIT_CONFIG_DIR/gitconfig_aliases"
    "$GIT_CONFIG_DIR/gitignore.global"
    "$GIT_CONFIG_DIR/shell_aliases"
  )
  local -a generated_actions=()
  local -a generated_descriptions=(
    "identity, signing and Git defaults"
    "delta themes and diff presentation"
    "global text and line-ending attributes"
    "Git command aliases"
    "global ignore patterns"
    "Git and GitHub shell shortcuts"
  )
  local file=""
  local template_file=""
  local index=0
  local line=""

  [[ -d $TEMPLATE_DIR ]] || {
    print_error "Missing configuration templates: $TEMPLATE_DIR"
    return 1
  }
  mkdir -p "$GIT_CONFIG_DIR"

  for file in "${generated_files[@]}"; do
    if [[ -e $file ]]; then
      generated_actions+=("Updated")
    else
      generated_actions+=("Created")
    fi
  done

  for index in "${!generated_files[@]}"; do
    file="${generated_files[$index]}"
    template_file="$TEMPLATE_DIR/${file##*/}"
    if [[ ${file##*/} == "config" ]]; then
      while IFS= read -r line || [[ -n $line ]]; do
        printf '%s\n' "${line//@CONFIG_DIR@/$GIT_CONFIG_DIR}"
      done < "$template_file" > "$file"
      git config --file "$file" user.name "$USER_NAME"
      git config --file "$file" user.email "$USER_EMAIL"
      git config --file "$file" user.signingkey "~/.ssh/id_ed25519.pub"
      git config --file "$file" gpg.format ssh
      git config --file "$file" commit.gpgsign true
      git config --file "$file" tag.gpgsign true
    else
      cp "$template_file" "$file"
    fi
  done

  chmod 0644 "${generated_files[@]}"

  print_info "Configuration directory: ${WHITE}$GIT_CONFIG_DIR${NC}"
  echo ""
  for index in "${!generated_files[@]}"; do
    print_success "${generated_actions[$index]}: ${WHITE}${generated_files[$index]}${NC}"
    echo -e "      ${GRAY}${generated_descriptions[$index]}${NC}"
  done

  echo ""
  print_info "Persistent Git customization: ${CYAN}nvim $GIT_CONFIG_DIR/gitconfig.local${NC}"
  echo -e "    ${GRAY}This optional file is loaded last and is never generated or overwritten.${NC}"

  echo ""
  print_info "Shell aliases: add ${CYAN}source $GIT_CONFIG_DIR/shell_aliases${NC} to ~/.zshrc"

  echo ""
  print_warn "Running 'git-setup config' or 'git-setup setup' rewrites the 6 generated files."

  echo ""
  print_info "To change their generated defaults, edit the templates in ${CYAN}$TEMPLATE_DIR${NC}."
  echo ""
}

setup_github_auth() {
  print_section "${ICON_GITHUB} GitHub Authentication"

  if gh auth status > /dev/null 2>&1; then
    local user=""
    user=$(gh api user -q .login 2> /dev/null || echo "unknown")
    local scopes=""
    scopes=$(gh auth status 2>&1 | grep -oP "Token scopes: '\K[^']+" || echo "unknown")
    print_success "Already authenticated as ${WHITE}@$user${NC}"
    print_info "Token scopes: ${GRAY}$scopes${NC}"
    echo -ne "  ${GRAY}Re-authenticate? (y/N):${NC} "
    read -r reauth
    if [[ ! $reauth =~ ^[yY]$ ]]; then
      return 0
    fi
    gh auth logout --hostname github.com
  fi

  print_step "Enter your GitHub Personal Access Token:"
  echo -ne "  ${GRAY}Token:${NC} "
  read -rs GITHUB_TOKEN
  echo ""

  if [[ -z $GITHUB_TOKEN ]]; then
    print_error "No token provided"
    return 1
  fi

  if echo "$GITHUB_TOKEN" | gh auth login --with-token --hostname github.com; then
    print_success "Authentication successful"
  else
    print_error "Authentication failed"
    return 1
  fi

  unset GITHUB_TOKEN
}

setup_ssh_key() {
  print_section "${ICON_KEY} SSH Key"

  if [[ -f ~/.ssh/id_ed25519 ]]; then
    print_success "Key already exists"
  else
    print_step "Generating ed25519 key..."
    mkdir -p ~/.ssh && chmod 700 ~/.ssh
    ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -N "" -C "$USER_EMAIL"
    print_success "Key generated"
  fi

  local key_title
  key_title="ravn-$(hostname)-$(date +%Y%m%d)"
  if gh ssh-key add ~/.ssh/id_ed25519.pub --title "$key_title" 2> /dev/null; then
    print_success "Authentication key added to GitHub"
  else
    print_info "Authentication key already on GitHub"
  fi

  if gh ssh-key add ~/.ssh/id_ed25519.pub --type signing --title "$key_title (Signing)" 2> /dev/null; then
    print_success "Signing key added to GitHub"
  else
    print_info "Signing key already on GitHub"
  fi
}

setup_gpg_key() {
  print_section "${ICON_LOCK} GPG Key"

  if gpg --list-secret-keys "$USER_NAME" 2> /dev/null | grep -q "$USER_NAME"; then
    print_success "Key already exists"
  else
    print_step "Generating RSA 4096 key..."
    cat > /tmp/gpg_batch << EOF
Key-Type: RSA
Key-Length: 4096
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: $USER_NAME
Name-Email: $USER_EMAIL
Expire-Date: 0
%no-protection
%commit
EOF
    gpg --batch --generate-key /tmp/gpg_batch
    rm -f /tmp/gpg_batch
    print_success "Key generated"
  fi

  GPG_KEY_ID=$(get_gpg_key_id)
  print_info "Key ID: ${WHITE}$GPG_KEY_ID${NC}"

  if [[ -n $GPG_KEY_ID ]]; then
    if gpg --armor --export "$GPG_KEY_ID" | gh gpg-key add - 2> /dev/null; then
      print_success "Key added to GitHub"
    else
      print_info "Key already on GitHub"
    fi
  fi
}

configure_signing() {
  print_section "${ICON_GEAR} Signing Configuration"

  echo -e "  Choose commit signing method:"
  echo -e "    ${CYAN}1${NC}  SSH (Recommended - uses ~/.ssh/id_ed25519.pub)"
  echo -e "    ${CYAN}2${NC}  GPG (Uses GPG key)"
  echo -e "    ${CYAN}3${NC}  None"
  echo ""
  echo -ne "  ${GRAY}Selection [1]:${NC} "
  read -r sign_choice
  sign_choice=${sign_choice:-1}

  # Ensure config directory exists
  mkdir -p "$(dirname "$GIT_CONFIG_FILE")"

  if [[ $sign_choice == "1" ]]; then
    git config --file "$GIT_CONFIG_FILE" gpg.format ssh
    git config --file "$GIT_CONFIG_FILE" user.signingkey "$HOME/.ssh/id_ed25519.pub"
    git config --file "$GIT_CONFIG_FILE" commit.gpgsign true
    git config --file "$GIT_CONFIG_FILE" tag.gpgsign true
    print_success "SSH signing configured in $GIT_CONFIG_FILE"
  elif [[ $sign_choice == "2" ]]; then
    GPG_KEY_ID=$(get_gpg_key_id)
    if [[ -z $GPG_KEY_ID ]]; then
      print_error "No GPG key available!"
      return 1
    fi
    git config --file "$GIT_CONFIG_FILE" gpg.format openpgp
    git config --file "$GIT_CONFIG_FILE" user.signingkey "$GPG_KEY_ID"
    git config --file "$GIT_CONFIG_FILE" commit.gpgsign true
    git config --file "$GIT_CONFIG_FILE" tag.gpgsign true
    print_success "GPG signing configured in $GIT_CONFIG_FILE (Key: $GPG_KEY_ID)"
  else
    git config --file "$GIT_CONFIG_FILE" commit.gpgsign false
    git config --file "$GIT_CONFIG_FILE" tag.gpgsign false
    print_info "Commit signing disabled in $GIT_CONFIG_FILE"
  fi

  git config --file "$GIT_CONFIG_FILE" init.defaultBranch master
  print_success "Default branch set to: ${WHITE}master${NC}"
}

configure_gpg_agent() {
  print_section "${ICON_GEAR} GPG Agent"

  mkdir -p ~/.gnupg && chmod 700 ~/.gnupg

  if [[ ! -f ~/.gnupg/gpg-agent.conf ]] || [[ ! -L ~/.gnupg/gpg-agent.conf ]]; then
    cat > ~/.gnupg/gpg-agent.conf << 'EOF'
default-cache-ttl 600
max-cache-ttl 7200
enable-ssh-support
EOF
    print_success "gpg-agent.conf created"
  else
    print_info "gpg-agent.conf exists"
  fi

  gpgconf --kill gpg-agent 2> /dev/null || true
  gpgconf --launch gpg-agent 2> /dev/null || true
  print_success "Agent restarted"
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Test Functions                                                               │
# └──────────────────────────────────────────────────────────────────────────────┘

run_test() {
  print_section "${ICON_ROCKET} Integration Test"

  local repo_name
  repo_name="test-git-$(date +%s)"
  local test_dir="/tmp/$repo_name"
  local test_passed=0
  local test_failed=0
  local pushed_to_github=false
  local commit_signed=false

  # Test 1: Create repository
  print_step "Creating test repository..."
  mkdir -p "$test_dir" && cd "$test_dir"
  if git init -b main > /dev/null 2>&1; then
    print_success "Git repository initialized"
    ((++test_passed))
  else
    print_error "Failed to initialize repository"
    ((++test_failed))
    cd - > /dev/null || true
    return 1
  fi

  # Test 2: Create file and stage
  {
    echo "# Test Repository"
    echo ""
    echo "This is a test repository created by git-setup"
    echo "Created: $(date)"
  } > README.md

  if git add README.md 2> /dev/null; then
    print_success "File staged"
    ((++test_passed))
  else
    print_error "Failed to stage file"
    ((++test_failed))
  fi

  # Test 3: Signed commit
  print_step "Testing signed commit..."
  local commit_output=""
  local commit_result=0
  commit_output=$(git commit -S -m "Test signed commit" 2>&1) || commit_result=$?
  if ((commit_result == 0)); then
    print_success "Signed commit created"
    commit_signed=true
    ((++test_passed))

    # Show commit details
    local commit_hash=""
    commit_hash=$(git rev-parse --short HEAD 2> /dev/null || echo "unknown")
    local commit_author=""
    commit_author=$(git log -1 --format='%an <%ae>' 2> /dev/null || echo "unknown")
    print_info "Commit: ${WHITE}$commit_hash${NC}"
    print_info "Author: ${GRAY}$commit_author${NC}"

    # Verify signature
    print_step "Verifying commit signature..."
    local verify_output=""
    verify_output=$(git log --show-signature -1 2>&1) || true
    if echo "$verify_output" | grep -q -E "Good signature|signature"; then
      print_success "Commit is signed & verified"
      ((++test_passed))
    else
      print_warn "Could not verify signature"
    fi
  else
    print_error "Signed commit failed"
    ((++test_failed))

    # Show why it failed
    if echo "$commit_output" | grep -q "No secret key"; then
      print_info "Reason: GPG/SSH key not found"
    else
      echo -e "    ${GRAY}Error: $commit_output${NC}"
    fi

    print_step "Trying unsigned commit..."
    if git -c commit.gpgsign=false commit -m "Test commit (unsigned)" > /dev/null 2>&1; then
      print_warn "Unsigned commit worked"
    else
      print_error "Even unsigned commit failed"
      ((++test_failed))
    fi
  fi

  # Test 4: Push to GitHub (optional)
  echo ""
  echo -ne "  ${GRAY}Push to GitHub? (y/N):${NC} "
  read -r do_push
  if [[ $do_push =~ ^[yY]$ ]]; then
    print_step "Creating repository on GitHub..."
    local gh_output=""
    local gh_result=0
    gh_output=$(gh repo create "$repo_name" --public --source=. --remote=origin --push 2>&1) || gh_result=$?
    if ((gh_result == 0)); then
      local user=""
      user=$(gh api user -q .login 2> /dev/null || echo "unknown")
      print_success "Repository created and pushed"
      print_info "URL: ${CYAN}https://github.com/$user/$repo_name${NC}"
      pushed_to_github=true
      ((++test_passed))
    else
      print_error "Push failed"
      ((++test_failed))
      echo -e "    ${GRAY}Error: $gh_output${NC}"
    fi
  else
    print_info "Skipped push to GitHub"
  fi

  # Summary
  echo ""
  print_section "󰄬 Test Summary"

  echo -e "  ${WHITE}Results:${NC}"
  echo -e "    ${GREEN}${ICON_CHECK} Passed:${NC} $test_passed"
  echo -e "    ${RED}${ICON_CROSS} Failed:${NC} $test_failed"
  echo ""
  echo -e "  ${WHITE}Details:${NC}"
  echo -e "    Repository:     ${GRAY}$test_dir${NC}"
  if [[ $commit_signed == "true" ]]; then
    echo -e "    Signed commit:  ${GREEN}Yes${NC}"
  else
    echo -e "    Signed commit:  ${RED}No${NC}"
  fi
  if [[ $pushed_to_github == "true" ]]; then
    local user=""
    user=$(gh api user -q .login 2> /dev/null || echo "unknown")
    echo -e "    GitHub:         ${GREEN}github.com/$user/$repo_name${NC}"
  else
    echo -e "    GitHub:         ${GRAY}Not pushed${NC}"
  fi

  # Overall status
  echo ""
  if ((test_failed == 0)); then
    print_success "All tests passed! Your Git setup is working correctly."
  else
    print_warn "Some tests failed. Check the details above."
  fi

  # Cleanup
  echo ""
  print_section "󰃢 Cleanup"

  # Delete local test directory
  cd - > /dev/null || true
  if rm -rf "$test_dir" 2> /dev/null; then
    print_success "Local test directory deleted"
  fi

  # Delete GitHub repository if it was created
  if [[ $pushed_to_github == "true" ]]; then
    local user=""
    user=$(gh api user -q .login 2> /dev/null || echo "unknown")
    print_step "Deleting GitHub repository ${GRAY}$user/$repo_name${NC}..."
    if gh repo delete "$user/$repo_name" --yes 2> /dev/null; then
      print_success "GitHub repository deleted"
    else
      print_warn "Could not delete GitHub repository"
      print_info "Delete manually: ${CYAN}gh repo delete $user/$repo_name --yes${NC}"
    fi
  fi

  print_success "Cleanup complete"
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Main Menu                                                                    │
# └──────────────────────────────────────────────────────────────────────────────┘

show_menu() {
  echo ""
  print_section "${RAVN_ICON[ui_command]} Choose an action"
  echo -e "  ${GREEN}1${NC}  ${RAVN_ICON[ui_check]}  Verify current configuration"
  echo -e "  ${GREEN}2${NC}  ${RAVN_ICON[ui_gear]}  Run full setup"
  echo -e "  ${GREEN}3${NC}  ${RAVN_ICON[ui_test]}  Run integration test"
  echo -e "  ${GREEN}4${NC}  ${RAVN_ICON[ui_trash]}  Clean local config (fresh start)"
  echo -e "  ${GREEN}q${NC}  ${RAVN_ICON[ui_close]}  Exit"
  echo ""
  echo -ne "  ${LIGHT_GRAY}Selection:${NC} "
}

do_verify() {
  verify_dependencies
  verify_git_config
  verify_generated_git_config_files
  verify_ssh
  verify_gpg
  verify_github_auth
}

do_setup() {
  generate_git_config_files
  verify_dependencies
  setup_github_auth
  setup_ssh_key
  setup_gpg_key
  configure_signing
  configure_gpg_agent

  print_header "${ICON_CHECK} Setup Complete"
}

do_clean() {
  print_header "󰃢 Clean Local Git Configuration"

  echo ""
  print_warn "This will remove locally created configuration files:"
  echo ""
  echo -e "    ${GRAY}SSH Keys:${NC}"
  echo -e "      • ~/.ssh/id_ed25519"
  echo -e "      • ~/.ssh/id_ed25519.pub"
  echo ""
  echo -e "    ${GRAY}GPG:${NC}"
  echo -e "      • All GPG secret keys for ${WHITE}$USER_NAME${NC}"
  echo -e "      • ~/.gnupg/gpg-agent.conf"
  echo ""
  echo -e "    ${GRAY}Git Configuration:${NC}"
  echo -e "      • ~/.config/git/config"
  echo -e "      • ~/.config/git/delta.gitconfig"
  echo -e "      • ~/.config/git/gitattributes.global"
  echo -e "      • ~/.config/git/gitconfig_aliases"
  echo -e "      • ~/.config/git/gitignore.global"
  echo -e "      • ~/.config/git/shell_aliases"
  echo -e "      ${GRAY}(gitconfig.local will be preserved)${NC}"
  echo ""
  echo -e "    ${GRAY}GitHub CLI:${NC}"
  echo -e "      • gh authentication token"
  echo ""
  echo -e "    ${RED}${ICON_WARN} This action cannot be undone!${NC}"
  echo ""
  echo -ne "  ${YELLOW}Are you sure? Type 'yes' to confirm:${NC} "
  read -r confirm

  if [[ $confirm != "yes" ]]; then
    print_info "Cancelled"
    return 0
  fi

  print_section "󰃢 Cleaning SSH Keys"

  if [[ -f ~/.ssh/id_ed25519 ]]; then
    rm -f ~/.ssh/id_ed25519 ~/.ssh/id_ed25519.pub
    print_success "Removed SSH keys"
  else
    print_info "No SSH keys found"
  fi

  print_section "󰃢 Cleaning GPG Keys"

  # Get all GPG key IDs for the user
  local gpg_keys=""
  gpg_keys=$(gpg --list-secret-keys --keyid-format LONG "$USER_EMAIL" 2> /dev/null | grep "^sec" | awk '{print $2}' | cut -d'/' -f2 || true)

  if [[ -n $gpg_keys ]]; then
    for key_id in $gpg_keys; do
      print_step "Removing GPG key: ${WHITE}$key_id${NC}"
      # Delete secret key first (required before public)
      gpg --batch --yes --delete-secret-keys "$key_id" 2> /dev/null || true
      gpg --batch --yes --delete-keys "$key_id" 2> /dev/null || true
      print_success "Removed key $key_id"
    done
  else
    print_info "No GPG keys found for $USER_EMAIL"
  fi

  # Remove gpg-agent.conf
  if [[ -f ~/.gnupg/gpg-agent.conf ]]; then
    rm -f ~/.gnupg/gpg-agent.conf
    print_success "Removed gpg-agent.conf"
  fi

  # Restart gpg-agent
  gpgconf --kill gpg-agent 2> /dev/null || true
  print_success "Stopped GPG agent"

  print_section "${ICON_GIT} Cleaning Git Configuration"

  local git_config_file=""
  local removed_git_config=0
  for git_config_file in \
    "$GIT_CONFIG_DIR/config" \
    "$GIT_CONFIG_DIR/delta.gitconfig" \
    "$GIT_CONFIG_DIR/gitattributes.global" \
    "$GIT_CONFIG_DIR/gitconfig_aliases" \
    "$GIT_CONFIG_DIR/gitignore.global" \
    "$GIT_CONFIG_DIR/shell_aliases"; do
    if [[ -f $git_config_file ]]; then
      rm -f "$git_config_file"
      print_success "Removed ${GRAY}${git_config_file/#$HOME/\~}${NC}"
      ((removed_git_config += 1))
    fi
  done
  if ((removed_git_config == 0)); then
    print_info "No generated Git configuration files found"
  else
    print_info "Preserved ${GRAY}~/.config/git/gitconfig.local${NC}"
  fi

  print_section "󰃢 Cleaning GitHub CLI"

  if gh auth status > /dev/null 2>&1; then
    gh auth logout --hostname github.com 2> /dev/null || true
    print_success "Logged out from GitHub CLI"
  else
    print_info "GitHub CLI not authenticated"
  fi

  print_section "${ICON_CHECK} Cleanup Complete"

  echo ""
  print_info "Your local git configuration has been reset."
  print_info "Run option ${WHITE}2${NC} (Full Setup) to reconfigure everything."
  echo ""
}

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Entry Point                                                                  │
# └──────────────────────────────────────────────────────────────────────────────┘

main() {
  clear || true
  local gh_user=""
  gh_user=$(gh api user -q .login 2> /dev/null || echo "ravn-ruby-path")
  echo -e "${CYAN}"
  cat << 'BANNER_EOF'
  ╭────────────────────────────────────────────────────╮
  │                                                    │
  │  ██████╗  █████╗ ██╗   ██╗███╗   ██╗               │
  │  ██╔══██╗██╔══██╗██║   ██║████╗  ██║               │
  │  ██████╔╝███████║██║   ██║██╔██╗ ██║               │
  │  ██╔══██╗██╔══██║╚██╗ ██╔╝██║╚██╗██║               │
  │  ██║  ██║██║  ██║ ╚████╔╝ ██║ ╚████║               │
  │  ╚═╝  ╚═╝╚═╝  ╚═╝  ╚═══╝  ╚═╝  ╚═══╝               │
  │                                                    │
  │   Git + GitHub + GPG Configuration for Arch Linux  │
  │                                                    │
BANNER_EOF
  echo -e "  │     ${GRAY}by Roberto Flores ${WHITE}@${gh_user}${CYAN}                  │"
  cat << 'BANNER_EOF'
  │                                                    │
  ╰────────────────────────────────────────────────────╯
BANNER_EOF
  echo -e "${NC}"

  # Handle command line arguments
  case "${1:-}" in
    verify | v | --verify | -v)
      do_verify
      exit 0
      ;;
    config | f | --config | -f)
      generate_git_config_files
      exit 0
      ;;
    setup | s | --setup | -s)
      do_setup
      exit 0
      ;;
    test | t | --test | -t)
      run_test
      exit 0
      ;;
    clean | c | --clean | -c)
      do_clean
      exit 0
      ;;
    help | h | --help | -h)
      echo "Usage: $0 [command]"
      echo ""
      echo "Commands:"
      echo "  verify   Check current configuration"
      echo "  config   Generate files in ~/.config/git"
      echo "  setup    Generate config and run full setup wizard"
      echo "  test     Run integration test"
      echo "  clean    Clean local config (fresh start)"
      echo ""
      echo "Run without arguments for interactive menu."
      exit 0
      ;;
  esac

  # Interactive mode
  while true; do
    show_menu
    read -r choice
    case $choice in
      1) do_verify ;;
      2) do_setup ;;
      3) run_test ;;
      4) do_clean ;;
      q | Q)
        echo ""
        print_info "Goodbye!"
        exit 0
        ;;
      *) print_error "Invalid option" ;;
    esac
    echo ""
    echo -ne "  ${GRAY}Press Enter to continue...${NC}"
    read -r
    clear || true
  done
}

main "$@"
